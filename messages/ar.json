    "q8": "\u0647\u0644 \u0647\u0630\u0627 \u0645\u0631\u062a\u0628\u0637 \u0628\u0640 5000.dev\u061f",
    "a8": "\u0644\u0627. 5000.live \u0645\u0634\u0631\u0648\u0639 \u0645\u0633\u062a\u0642\u0644 \u0645\u0646 We Pioners LTD \u0628\u0631\u064a\u0637\u0627\u0646\u064a\u0627\u060c \u064a\u0631\u0643\u0651\u0632 \u062d\u0635\u0631\u0627\u064b \u0639\u0644\u0649 \u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0627\u0644\u062c\u0648\u0627\u0644 \u0627\u0644\u0623\u0635\u0644\u064a\u0629 \u0644\u0644\u0634\u0631\u0642 \u0627\u0644\u0623\u0648\u0633\u0637 \u0648\u0627\u0644\u062e\u0644\u064a\u062c. 5000.dev \u0634\u0631\u0643\u0629 \u0645\u0646\u0641\u0635\u0644\u0629 \u062a\u0645\u0627\u0645\u0627\u064b."
