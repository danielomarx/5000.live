    "body": "\u0646\u062d\u0646 \u0648\u0627\u062b\u0642\u0648\u0646 \u0645\u0646 \u0639\u0645\u0644\u064a\u062a\u0646\u0627 \u0644\u062f\u0631\u062c\u0629 \u0623\u0646\u0646\u0627 \u0646\u0642\u062f\u0645 \u0627\u0633\u062a\u0631\u062f\u0627\u062f\u0627\u064b \u0643\u0627\u0645\u0644\u0627\u064b \u0625\u0630\u0627 \u0644\u0645 \u0646\u0633\u0644\u0651\u0645 \u062e\u0644\u0627\u0644 4 \u0623\u0633\u0627\u0628\u064a\u0639. \u0628\u062f\u0648\u0646 \u0623\u0633\u0626\u0644\u0629. \u0628\u062f\u0648\u0646 \u0645\u0641\u0627\u0648\u0636\u0627\u062a. \u0647\u0630\u0627 \u0648\u0639\u062f\u0646\u0627 \u2014 \u0648\u0627\u0644\u0645\u062e\u0627\u0637\u0631\u0629 \u0639\u0644\u064a\u0646\u0627 \u0646\u062d\u0646\u060c \u0644\u064a\u0633\u062a \u0639\u0644\u064a\u0643.",
