  "faq": {
    "tag": "\u0627\u0644\u0623\u0633\u0626\u0644\u0629 \u0627\u0644\u0634\u0627\u0626\u0639\u0629",
    "title": "\u0623\u0633\u0626\u0644\u0629\u061f \u0625\u062c\u0627\u0628\u0627\u062a.",
    "q1": "\u0647\u0644 \u062a\u0628\u0646\u0648\u0646 \u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0623\u0635\u0644\u064a\u0629 \u0623\u0645 \u062a\u0637\u0628\u064a\u0642\u0627\u062a \u0648\u064a\u0628\u061f",
    "a1": "\u0646\u0628\u0646\u064a \u062a\u0637\u0628\u064a\u0642\u0627\u062a \u062c\u0648\u0627\u0644 \u0623\u0635\u0644\u064a\u0629 \u062d\u0642\u064a\u0642\u064a\u0629 \u0628\u0627\u0633\u062a\u062e\u062f\u0627\u0645 React Native \u0623\u0648 Flutter. \u062a\u0637\u0628\u064a\u0642\u0627\u062a \u062d\u0642\u064a\u0642\u064a\u0629 \u062a\u064f\u0646\u0634\u0631 \u0639\u0644\u0649 App Store \u0648Google Play \u2014 \u0644\u064a\u0633\u062a \u0645\u0648\u0627\u0642\u0639 \u0648\u064a\u0628 \u0645\u063a\u0644\u0641\u0629.",
    "q2": "\u0645\u0627\u0630\u0627 \u0644\u0648 \u0643\u0627\u0646\u062a \u0641\u0643\u0631\u0629 \u062a\u0637\u0628\u064a\u0642\u064a \u0645\u0639\u0642\u062f\u0629\u061f",
    "a2": "\u0646\u062d\u062f\u062f \u0646\u0637\u0627\u0642 \u0623\u0648\u0644 \u0648\u062d\u062f\u0629 \u0644\u062a\u0633\u0644\u064a\u0645 MVP \u0635\u0627\u0644\u062d \u0644\u0644\u0625\u0637\u0644\u0627\u0642 \u062e\u0644\u0627\u0644 4 \u0623\u0633\u0627\u0628\u064a\u0639. \u0627\u0644\u0645\u0634\u0627\u0631\u064a\u0639 \u0627\u0644\u0645\u0639\u0642\u062f\u0629 \u062a\u064f\u0642\u0633\u0651\u0645 \u0625\u0644\u0649 \u0648\u062d\u062f\u0627\u062a \u0645\u062a\u062a\u0627\u0644\u064a\u0629 \u0628\u0640 $5,000. \u0623\u0646\u062a \u062a\u062a\u062d\u0643\u0645 \u0641\u064a \u062e\u0627\u0631\u0637\u0629 \u0627\u0644\u0637\u0631\u064a\u0642.",
    "q3": "\u0645\u0627\u0630\u0627 \u064a\u062d\u062f\u062b \u0628\u0639\u062f \u0627\u0644\u0623\u0631\u0628\u0639\u0629 \u0623\u0633\u0627\u0628\u064a\u0639\u061f",
    "a3": "\u0646\u0633\u0644\u0651\u0645 APK\u060c \u0648\u0646\u0631\u0641\u0639 \u0639\u0644\u0649 \u0643\u0644\u0627 \u0627\u0644\u0645\u062a\u062c\u0631\u064a\u0646\u060c \u0648\u0646\u0642\u062f\u0651\u0645 \u0623\u0633\u0628\u0648\u0639\u064a\u0646 \u062f\u0639\u0645 \u0625\u0635\u0644\u0627\u062d. \u0627\u0644\u0643\u0648\u062f \u0645\u0644\u0643\u0643 \u0628\u0627\u0644\u0643\u0627\u0645\u0644. \u0646\u0648\u0627\u0635\u0644 \u0628\u0640 $5,000 \u0644\u0643\u0644 \u0648\u062d\u062f\u0629.",
    "q4": "\u0647\u0644 \u0627\u0644\u062a\u0635\u0645\u064a\u0645 \u0645\u0634\u0645\u0648\u0644\u061f",
    "a4": "\u0646\u0639\u0645. \u062a\u0635\u0645\u064a\u0645 UI/UX \u0648\u0627\u0644\u0645\u062e\u0637\u0637\u0627\u062a \u0648\u062c\u0645\u064a\u0639 \u0634\u0627\u0634\u0627\u062a \u0627\u0644\u062a\u0637\u0628\u064a\u0642 \u0645\u0634\u0645\u0648\u0644\u0629 \u0628\u0627\u0644\u0643\u0627\u0645\u0644 \u0636\u0645\u0646 \u0627\u0644\u0640 $5,000. \u0644\u0627 \u062a\u0648\u062c\u062f \u0631\u0633\u0648\u0645 \u062a\u0635\u0645\u064a\u0645 \u0625\u0636\u0627\u0641\u064a\u0629.",
    "q5": "\u0647\u0644 \u062a\u0639\u0645\u0644\u0648\u0646 \u0645\u0639 \u0639\u0645\u0644\u0627\u0621 \u0641\u064a \u0627\u0644\u062e\u0644\u064a\u062c \u0648\u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0623\u0648\u0633\u0637\u061f",
    "a5": "\u0628\u0627\u0644\u062a\u0623\u0643\u064a\u062f. \u0646\u0639\u0645\u0644 \u0639\u0646 \u0628\u064f\u0639\u062f 100% \u0648\u0646\u062e\u062f\u0645 \u0639\u0645\u0644\u0627\u0621 \u062d\u0648\u0644 \u0627\u0644\u0639\u0627\u0644\u0645. \u0646\u0631\u0643\u0651\u0632 \u0628\u0634\u0643\u0644 \u062e\u0627\u0635 \u0639\u0644\u0649 \u0631\u0648\u0627\u062f \u0627\u0644\u0623\u0639\u0645\u0627\u0644 \u0641\u064a \u0627\u0644\u0625\u0645\u0627\u0631\u0627\u062a \u0648\u0627\u0644\u0633\u0639\u0648\u062f\u064a\u0629 \u0648\u0642\u0637\u0631 \u0648\u0627\u0644\u0643\u0648\u064a\u062a \u0648\u0627\u0644\u0628\u062d\u0631\u064a\u0646.",
    "q6": "\u0645\u0627 \u0627\u0644\u062a\u0642\u0646\u064a\u0627\u062a \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u0629\u061f",
